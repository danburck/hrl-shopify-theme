<!-- Sticky black nav bar — sticks at top once announcement bar scrolls away -->
<header class="site-header" role="banner">
  <div class="site-header__inner">

    <!-- ── DESKTOP LEFT / MOBILE CENTER : HRL Logo ── -->
    <div class="site-header__logo">
      <a href="/" aria-label="{{ shop.name }} — home">
        <img
          src="{{ 'HRL_logo.svg' | asset_url }}"
          alt="{{ shop.name }}"
          class="site-header__logo-img"
          width="108"
          height="53"
          loading="eager"
        >
      </a>
    </div>

    <!-- ── CENTER : Yellow Blurb (desktop only — clickable/alive) ── -->
    <a
      href="/pages/manifesto"
      class="site-header__blurb"
      aria-label="Manifesto"
    >
      <img
        src="{{ 'yellow_blurb.svg' | asset_url }}"
        alt=""
        class="blurb__svg"
        width="70"
        height="70"
        aria-hidden="true"
        draggable="false"
      >
    </a>

    <!-- ── Mobile Menu Button (mobile only — hamburger opens nav drawer) ── -->
    <button
      id="mobile-nav-toggle"
      class="site-header__menu-toggle"
      aria-label="Open navigation"
      aria-controls="mobile-nav-drawer"
      aria-expanded="false"
    >
      <svg
        viewBox="0 0 24 24"
        width="24"
        height="24"
        aria-hidden="true"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      >
        <line x1="3" y1="6" x2="21" y2="6" stroke="#fffb29" />
        <line x1="3" y1="12" x2="21" y2="12" stroke="#fffb29" />
        <line x1="3" y1="18" x2="21" y2="18" stroke="#fffb29" />
      </svg>
    </button>

    <!-- ── DESKTOP RIGHT : nav links + cart ── -->
    <nav class="site-header__nav" aria-label="Main navigation">
      <a href="/pages/journal-club" class="nav-link">Journal Club</a>
      <a href="/pages/schedule" class="nav-link">Schedule</a>
      <a href="/pages/caps" class="nav-link">Caps</a>
      <button
        class="nav-link cart-toggle"
        data-cart-toggle
        aria-label="Open cart"
        aria-controls="cart-drawer"
        aria-expanded="false"
        style="{% if cart.item_count == 0 %}display:none{% endif %}"
      >Cart <span data-cart-count>({{ cart.item_count }})</span></button>
    </nav>

    <!-- ── MOBILE RIGHT : cart count only, e.g. "(1)" ── -->
    <button
      id="mobile-cart-toggle"
      class="site-header__mobile-cart nav-link"
      aria-label="Open cart"
      style="{% if cart.item_count == 0 %}display:none{% endif %}"
    ><span data-cart-count>({{ cart.item_count }})</span></button>

  </div>
</header>
