<!-- Cart Drawer Overlay -->
<div
  id="cart-drawer-overlay"
  class="cart-drawer-overlay"
  aria-hidden="true"
></div>

<!-- Cart Drawer -->
<aside
  id="cart-drawer"
  class="cart-drawer"
  role="dialog"
  aria-label="Shopping cart"
  aria-modal="true"
  aria-hidden="true"
>

  <!-- Header -->
  <div class="cart-drawer__header">
    <span class="cart-drawer__title">
      Cart <span class="cart-drawer__count" data-cart-title-count>
        {%- if cart.item_count > 0 -%}({{ cart.item_count }}){%- else -%}(2){%- endif -%}
      </span>
    </span>
    <button
      id="cart-drawer-close"
      class="cart-drawer__close"
      aria-label="Close cart"
    >&#x2715;</button>
  </div>

  <!-- Items -->
  <!-- Loading spinner — shown while cart refreshes -->
  <div class="cart-drawer__loader" id="cart-drawer-loader" aria-hidden="true">
    <span class="cart-drawer__spinner"></span>
  </div>

  <div class="cart-drawer__body" id="cart-drawer-items" style="display:none">

    {%- comment -%}
      PRODUCTION: the real Liquid loop fires when cart.item_count > 0.
      The mockup block below is visible in local dev (empty cart).
    {%- endcomment -%}

    {%- if cart.item_count > 0 -%}

      {%- for item in cart.items -%}
        <div class="cart-item" data-line-item="{{ item.key }}" data-unit-price="{{ item.price }}">
          <div class="cart-item__image-wrap">
            <img
              class="cart-item__image"
              src="{{ item.image | image_url: width: 200 }}"
              alt="{{ item.title | escape }}"
              loading="lazy"
            >
          </div>
          <div class="cart-item__details">
            <div class="cart-item__name-row">
              <span class="cart-item__name">{{ item.product.title }}</span>
              <span class="cart-item__price">{{ item.final_line_price | money }}</span>
            </div>
            {%- if item.variant.title != 'Default Title' -%}
              <span class="cart-item__variant">{{ item.variant.title }}</span>
            {%- endif -%}
            <div class="cart-item__qty-wrap">
              <button class="cart-item__qty-btn" data-action="decrease" data-line-key="{{ item.key }}" aria-label="Decrease quantity">&#x2212;</button>
              <span class="cart-item__qty-val">{{ item.quantity }}</span>
              <button class="cart-item__qty-btn" data-action="increase" data-line-key="{{ item.key }}" aria-label="Increase quantity">+</button>
            </div>
          </div>
        </div>
      {%- endfor -%}

    {%- else -%}

      {%- comment -%} ── MOCKUP — visible in local dev when cart is empty ── {%- endcomment -%}
      <div class="cart-item" data-mockup-item>
        <div class="cart-item__image-wrap">
          <div class="cart-item__image-placeholder" aria-hidden="true"></div>
        </div>
        <div class="cart-item__details">
          <div class="cart-item__name-row">
            <span class="cart-item__name">Seeker Tee</span>
            <span class="cart-item__price" data-item-price="95">€95</span>
          </div>
          <span class="cart-item__variant">Marigold / Size M</span>
          <div class="cart-item__qty-wrap">
            <button class="cart-item__qty-btn" data-action="decrease" aria-label="Decrease">&#x2212;</button>
            <span class="cart-item__qty-val">1</span>
            <button class="cart-item__qty-btn" data-action="increase" aria-label="Increase">+</button>
          </div>
        </div>
      </div>

      <div class="cart-item" data-mockup-item>
        <div class="cart-item__image-wrap">
          <div class="cart-item__image-placeholder" aria-hidden="true"></div>
        </div>
        <div class="cart-item__details">
          <div class="cart-item__name-row">
            <span class="cart-item__name">Canvas Hoodie</span>
            <span class="cart-item__price" data-item-price="145">€145</span>
          </div>
          <span class="cart-item__variant">Black / Size L</span>
          <div class="cart-item__qty-wrap">
            <button class="cart-item__qty-btn" data-action="decrease" aria-label="Decrease">&#x2212;</button>
            <span class="cart-item__qty-val">1</span>
            <button class="cart-item__qty-btn" data-action="increase" aria-label="Increase">+</button>
          </div>
        </div>
      </div>

    {%- endif -%}

  </div>

  <!-- Footer -->
  <div class="cart-drawer__footer">
    <div class="cart-drawer__subtotal">
      <span class="cart-drawer__subtotal-label">Total</span>
      <span class="cart-drawer__subtotal-price" id="cart-subtotal">
        {%- if cart.item_count > 0 -%}
          {{ cart.total_price | money }}
        {%- else -%}
          €240
        {%- endif -%}
      </span>
    </div>
    <p class="cart-drawer__shipping-note">Pickup information at checkout</p>
    <a href="/checkout" class="btn-checkout{% if cart.item_count == 0 %} btn-checkout--disabled{% endif %}"
      style="{% if cart.item_count == 0 %}pointer-events:none;opacity:0.35{% endif %}">Checkout</a>
  </div>

</aside>
