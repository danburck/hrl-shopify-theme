<section class="page-home">
  <div class="page-home__inner">

    <!-- ── Hero: the offer ── -->
    <header class="page-home__hero">
      <p class="page-home__wordmark">HRL</p>

      <h1 class="page-home__title">
        Get to know your <em>self</em>.<br>
        Learn to listen.<br>
        Live a life that's <em>aligned</em> with you.
      </h1>

      <p class="page-home__subtitle">Alone, and in community.</p>

      <p class="page-home__intro">
        Hyper Real Love is a practice — a weekly ritual of meditation, journaling
        and honest connection for people who feel they've been living on autopilot
        and want to find their way back to themselves.
      </p>

      <div class="page-home__hero-cta">
        <a href="/pages/letters" class="page-home__cta-btn">Start with five free letters &rarr;</a>
        <p class="page-home__cta-note">Or jump straight in: <a href="#home-form" class="page-home__cta-link">join the Journal Club</a> — Saturdays, 25 minutes, free.</p>
      </div>
    </header>

    <!-- ── Recognition ── -->
    <div class="page-home__section">
      <h2 class="page-home__heading">Sound familiar?</h2>

      <ul class="page-home__mirror">
        <li>Success on paper. Emptiness within.</li>
        <li>Every birthday adds pressure, expectations, facades.</li>
        <li>You've outgrown the highlight reel but don't know what's underneath.</li>
        <li>The questions come at night: <em>who am I beneath all this?</em></li>
      </ul>

      <p class="page-home__body-em">
        The questions aren't the problem. They're the beginning.
      </p>
    </div>

    <!-- ── The journey ── -->
    <div class="page-home__section">
      <h2 class="page-home__heading">The journey</h2>

      <ol class="page-home__steps">
        <li>
          <span class="page-home__step-num">01 — Read</span>
          <span class="page-home__step-title">Five free letters</span>
          <span class="page-home__step-sub">Five days, five short letters. One honest story and one practice in each. <a href="/pages/letters">Start here &rarr;</a></span>
        </li>
        <li>
          <span class="page-home__step-num">02 — Practice</span>
          <span class="page-home__step-title">The Journal Club</span>
          <span class="page-home__step-sub">Every Saturday morning, online, free. 5 minutes meditation, 15 minutes journaling, 5 minutes connection. Pen, paper, you.</span>
        </li>
        <li>
          <span class="page-home__step-num">03 — Connect</span>
          <span class="page-home__step-title">Gatherings &amp; drops</span>
          <span class="page-home__step-sub">Journal Club events in your city. Limited cap releases you pick up in person — a reminder you wear, not merch.</span>
        </li>
        <li>
          <span class="page-home__step-num">04 — Go deeper</span>
          <span class="page-home__step-title">1:1 guidance</span>
          <span class="page-home__step-sub">When the questions get specific, work with me directly. By application, when you're ready.</span>
        </li>
      </ol>
    </div>

    <!-- ── Social proof ── -->
    <div class="page-home__section page-home__proof">
      <p class="page-home__member-count">
        <span class="page-home__dot"></span>
        126 seekers practice with us
      </p>

      <blockquote class="page-home__quote">
        &#8220;Every week I cannot wait for our time together. Even when I'm rushing through
        the chaos of daily life, I think about Saturday morning — that dedicated time where
        we untangle the week, observe our patterns and practice acceptance.&#8221;
      </blockquote>
    </div>

    <!-- ── Two paths ── -->
    <div class="page-home__section">
      <h2 class="page-home__heading">Two ways this goes</h2>

      <div class="page-home__paths">
        <div class="page-home__path">
          <p class="page-home__path-label">Path A</p>
          <p class="page-home__path-text">Another year on autopilot. Same scroll, same hollow wins, same question at night — a little quieter, a little harder to hear.</p>
        </div>
        <div class="page-home__path page-home__path--b">
          <p class="page-home__path-label">Path B</p>
          <p class="page-home__path-text">25 minutes this Saturday. Pen and paper. You start listening — and begin building a life that feels real. Hyper real.</p>
        </div>
      </div>
    </div>

    <!-- ── Final CTA + form ── -->
    <div class="page-home__section page-home__final" id="home-form">
      <h2 class="page-home__heading page-home__final-heading">Join the Journal Club</h2>
      <p class="page-home__body-em">
        This is your invitation to practice raising individual consciousness, together.<br>
        Five letters first, then Saturdays — it's online and it's free.
      </p>

      <div class="page-home__form">
        <script async data-uid="a433277e18" src="https://hyper-real-love-2.kit.com/a433277e18/index.js"></script>
      </div>

      <p class="page-home__cta-note">Free. No spam. Every reply reaches me personally.</p>
    </div>

  </div>
</section>

<style>
.page-home {
  min-height: 100vh;
  padding: 140px var(--space-6) var(--space-20);
  color: var(--color-yellow);
}

.page-home__inner {
  max-width: 680px;
  margin: 0 auto;
}

/* ── Hero ── */
.page-home__hero {
  text-align: center;
  margin-bottom: var(--space-20);
}

.page-home__wordmark {
  font-family: var(--font-title);
  font-size: 64px;
  font-weight: 700;
  line-height: 1;
  margin-bottom: var(--space-8);
}

.page-home__title {
  font-family: var(--font-body);
  font-weight: 400;
  font-size: clamp(32px, 5.5vw, 52px);
  line-height: 1.2;
  margin-bottom: var(--space-4);
}

.page-home__title em { font-style: italic; }

.page-home__subtitle {
  font-family: var(--font-body);
  font-size: var(--text-xl);
  font-style: italic;
  opacity: 0.8;
  margin-bottom: var(--space-8);
}

.page-home__intro {
  font-family: var(--font-body);
  font-size: var(--text-lg);
  line-height: 1.7;
  opacity: 0.9;
  max-width: 560px;
  margin: 0 auto var(--space-10);
}

.page-home__cta-btn {
  display: inline-block;
  font-family: var(--font-body);
  font-size: var(--text-lg);
  color: var(--color-black);
  background: var(--color-yellow);
  padding: 14px 36px;
  border-radius: 6px;
  text-decoration: none;
  font-weight: 700;
  transition: opacity var(--transition-fast), transform var(--transition-fast);
}

.page-home__cta-btn:hover {
  opacity: 0.85;
  transform: scale(1.03);
}

.page-home__cta-note {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-style: italic;
  opacity: 0.65;
  line-height: 1.6;
  margin-top: var(--space-4);
}

.page-home__cta-link {
  color: var(--color-yellow);
  text-decoration: underline;
}

/* ── Sections ── */
.page-home__section {
  margin-bottom: var(--space-20);
}

.page-home__heading {
  font-family: var(--font-body);
  font-weight: 400;
  font-size: clamp(24px, 4vw, 34px);
  line-height: 1.25;
  margin-bottom: var(--space-6);
}

.page-home__body-em {
  font-family: var(--font-body);
  font-size: var(--text-lg);
  font-style: italic;
  line-height: 1.7;
  margin-top: var(--space-6);
}

/* ── Mirror list ── */
.page-home__mirror {
  list-style: none;
  padding: 0;
}

.page-home__mirror li {
  font-family: var(--font-body);
  font-size: var(--text-md);
  line-height: 1.7;
  padding: var(--space-3) 0 var(--space-3) var(--space-6);
  position: relative;
  border-bottom: 1px solid rgba(255, 251, 41, 0.15);
}

.page-home__mirror li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--color-yellow);
  opacity: 0.6;
}

/* ── Journey steps ── */
.page-home__steps {
  list-style: none;
  padding: 0;
}

.page-home__steps li {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  padding: var(--space-5) 0;
  border-bottom: 1px solid rgba(255, 251, 41, 0.15);
}

.page-home__step-num {
  font-family: var(--font-title);
  font-size: var(--text-sm);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  opacity: 0.55;
}

.page-home__step-title {
  font-family: var(--font-body);
  font-size: var(--text-xl);
  line-height: 1.4;
}

.page-home__step-sub {
  font-family: var(--font-body);
  font-size: var(--text-md);
  font-style: italic;
  line-height: 1.6;
  opacity: 0.75;
}

.page-home__step-sub a {
  color: var(--color-yellow);
  text-decoration: underline;
}

/* ── Social proof ── */
.page-home__proof { text-align: center; }

.page-home__member-count {
  font-family: var(--font-body);
  font-size: var(--text-md);
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: var(--space-6);
}

.page-home__dot {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: var(--color-yellow);
  animation: home-pulse 2s ease-in-out infinite;
}

@keyframes home-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%      { opacity: 0.4; transform: scale(0.8); }
}

.page-home__quote {
  font-family: var(--font-body);
  font-size: var(--text-lg);
  font-style: italic;
  line-height: 1.7;
  opacity: 0.85;
  max-width: 560px;
  margin: 0 auto;
}

/* ── Two paths ── */
.page-home__paths {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-6);
}

.page-home__path {
  border: 1px solid rgba(255, 251, 41, 0.25);
  border-radius: 8px;
  padding: var(--space-6);
  opacity: 0.6;
}

.page-home__path--b {
  opacity: 1;
  border-color: var(--color-yellow);
}

.page-home__path-label {
  font-family: var(--font-title);
  font-size: var(--text-sm);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: var(--space-3);
}

.page-home__path-text {
  font-family: var(--font-body);
  font-size: var(--text-md);
  line-height: 1.7;
}

/* ── Final CTA ── */
.page-home__final {
  text-align: center;
  margin-bottom: 0;
  scroll-margin-top: 120px;
}

.page-home__final-heading { margin-bottom: var(--space-3); }

.page-home__form {
  max-width: 480px;
  margin: var(--space-8) auto 0;
}

/* ── Mobile ── */
@media (max-width: 768px) {
  .page-home { padding-top: 120px; }
  .page-home__hero { margin-bottom: var(--space-16); }
  .page-home__section { margin-bottom: var(--space-16); }
  .page-home__wordmark { font-size: 48px; }
  .page-home__paths { grid-template-columns: 1fr; }
}
</style>

