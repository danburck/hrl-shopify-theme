{% comment %}
  Homepage — Product Grid
  8 slots: only SEEKER (row 1, col 1) is active/clickable.
  Desktop: 4 columns × 2 rows with tagline spanning full width between rows.
  Mobile:  2 columns × 4 rows.
  Active product: full opacity, yellow text.
  Locked products: dimmed image + muted text.
{% endcomment %}

{%- assign active_handle = 'seeker' -%}
{%- assign all_products = collections.all.products -%}

<section class="main-collection" aria-label="Products">
  <div class="product-grid">

    {%- comment -%}── Slot 1: SEEKER (active) ──{%- endcomment -%}
    {%- assign seeker = all_products | where: 'handle', active_handle | first -%}
    <a href="{{ seeker.url }}" class="product-card product-card--active" aria-label="{{ seeker.title }}">
      <div class="product-card__image-wrap">
        {%- if seeker.featured_image -%}
          <img
            class="product-card__image"
            src="{{ seeker.featured_image | image_url: width: 600 }}"
            alt="{{ seeker.featured_image.alt | escape | default: seeker.title }}"
            width="600"
            height="700"
            loading="eager"
          >
        {%- else -%}
          <div class="product-card__image product-card__image--empty"></div>
        {%- endif -%}
      </div>
      <div class="product-card__info">
        <p class="product-card__name">{{ seeker.title }}</p>
        <p class="product-card__price">{{ seeker.selected_or_first_available_variant.price | money }}</p>
      </div>
    </a>

    {%- comment -%}── Row 1: slots 2–4 — 3 locked placeholders ──{%- endcomment -%}
    {%- for i in (1..3) -%}
      <div class="product-card product-card--locked product-card--deep" aria-hidden="true">
        <div class="product-card__image-wrap">
          <img class="product-card__image" src="{{ 'cap-hidden.webp' | asset_url }}" alt="" width="600" height="700" loading="lazy">
        </div>
        <div class="product-card__info">
          <p class="product-card__name">?</p>
          <p class="product-card__price">?</p>
        </div>
      </div>
    {%- endfor -%}

    {%- comment -%}── TAGLINE spanning all 4 columns ──{%- endcomment -%}
    <div class="product-grid__tagline" aria-hidden="true">
      <em>which one are you right now?</em>
    </div>

    {%- comment -%}── Row 2: slots 5–8 — 4 locked placeholders ──{%- endcomment -%}
    {%- for i in (1..4) -%}
      <div class="product-card product-card--locked product-card--deep" aria-hidden="true">
        <div class="product-card__image-wrap">
          <img class="product-card__image" src="{{ 'cap-hidden.webp' | asset_url }}" alt="" width="600" height="700" loading="lazy">
        </div>
        <div class="product-card__info">
          <p class="product-card__name">?</p>
          <p class="product-card__price">?</p>
        </div>
      </div>
    {%- endfor -%}

  </div>
</section>

{% schema %}
{
  "name": "Product Grid",
  "settings": []
}
{% endschema %}
