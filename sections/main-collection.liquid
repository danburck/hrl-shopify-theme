{% comment %}
  Homepage — Product Grid
  8 slots: only SEEKER (row 1, col 1) is active/clickable.
  Desktop: 4 columns × 2 rows with tagline spanning full width between rows.
  Mobile:  2 columns × 4 rows.
  Active product: full opacity, yellow text.
  Locked products: dimmed image + muted text.
{% endcomment %}

{%- assign active_handle = 'seeker-black' -%}
{%- assign all_products = collections.all.products -%}

<section class="main-collection" aria-label="Products">
  <div class="product-grid">

    {%- comment -%}── ROW 1 (slots 1–4) ──{%- endcomment -%}
    {%- for i in (0..3) -%}
      {%- assign product = all_products[i] -%}
      {%- assign is_active = false -%}
      {%- if product.handle == active_handle -%}{%- assign is_active = true -%}{%- endif -%}

      {%- if is_active -%}
        <a href="{{ product.url }}" class="product-card product-card--active" aria-label="{{ product.title }}">
      {%- else -%}
        <div class="product-card product-card--locked" aria-hidden="true">
      {%- endif -%}

        <div class="product-card__image-wrap">
          {%- if product.featured_image -%}
            <img
              class="product-card__image"
              src="{{ product.featured_image | image_url: width: 600 }}"
              alt="{{ product.featured_image.alt | escape | default: product.title }}"
              width="600"
              height="700"
              loading="{%- if i == 0 -%}eager{%- else -%}lazy{%- endif -%}"
            >
          {%- else -%}
            <div class="product-card__image product-card__image--empty"></div>
          {%- endif -%}
        </div>

        <div class="product-card__info">
          <p class="product-card__name">{{ product.title }}</p>
          <p class="product-card__price">{{ product.selected_or_first_available_variant.price | money }}</p>
        </div>

      {%- if is_active -%}</a>{%- else -%}</div>{%- endif -%}
    {%- endfor -%}

    {%- comment -%}── TAGLINE spanning all 4 columns ──{%- endcomment -%}
    <div class="product-grid__tagline" aria-hidden="true">
      <em>which one are you right now?</em>
    </div>

    {%- comment -%}── ROW 2 (slots 5–8) — all locked ──{%- endcomment -%}
    {%- for i in (4..7) -%}
      {%- assign product = all_products[i] -%}

      <div class="product-card product-card--locked product-card--deep" aria-hidden="true">
        <div class="product-card__image-wrap">
          {%- if product.featured_image -%}
            <img
              class="product-card__image"
              src="{{ product.featured_image | image_url: width: 600 }}"
              alt=""
              width="600"
              height="700"
              loading="lazy"
            >
          {%- else -%}
            <div class="product-card__image product-card__image--empty"></div>
          {%- endif -%}
        </div>

        <div class="product-card__info">
          <p class="product-card__name">{{ product.title }}</p>
          <p class="product-card__price">{{ product.selected_or_first_available_variant.price | money }}</p>
        </div>
      </div>
    {%- endfor -%}

  </div>
</section>

{% schema %}
{
  "name": "Product Grid",
  "settings": []
}
{% endschema %}
