<style>
.page-spaces {
  background-color: var(--color-black);
  min-height: 100vh;
  width: 100%;
}

.page-spaces__inner {
  padding: 80px var(--space-6) 120px;
  max-width: 860px;
  margin: 0 auto;
}

.page-spaces__hero {
  text-align: center;
  margin-bottom: 48px;
}

.page-spaces__title {
  font-family: var(--font-body);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(48px, 8vw, 96px);
  color: var(--color-yellow);
  margin: 0 0 16px;
}

.page-spaces__tagline {
  font-family: var(--font-body);
  font-style: italic;
  font-size: var(--text-md);
  color: var(--color-yellow);
  opacity: 0.7;
  max-width: 560px;
  margin: 0 auto;
  line-height: 1.6;
}

/* Yellow card */
.page-spaces__card {
  background-color: var(--color-yellow);
  border-radius: 4px;
  padding: 40px 48px 48px;
}

/* Month + theme header */
.page-spaces__month-header {
  text-align: center;
  margin-bottom: 32px;
  padding-bottom: 32px;
  border-bottom: 1px solid rgba(0,0,0,0.15);
}

.page-spaces__month-title {
  font-family: var(--font-body);
  font-weight: 400;
  font-size: clamp(32px, 5vw, 52px);
  color: var(--color-black);
  margin: 0 0 10px;
  letter-spacing: -0.01em;
}

.page-spaces__theme-line {
  font-family: var(--font-body);
  font-size: clamp(16px, 2.5vw, 22px);
  font-weight: 700;
  color: var(--color-black);
  margin: 0;
  letter-spacing: 0.01em;
}

.page-spaces__theme-label {
  font-weight: 700;
  margin-right: 4px;
  opacity: 0.5;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  display: block;
  margin-bottom: 2px;
}

/* Event cards */
.spaces-event {
  display: grid;
  grid-template-columns: 90px 1fr auto;
  gap: 32px;
  align-items: center;
  padding: 28px 0;
  border-top: 1px solid rgba(0, 0, 0, 0.12);
}

.spaces-event:first-child {
  border-top: none;
}

.spaces-event__date-col {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  font-family: var(--font-body);
  color: var(--color-black);
}

.spaces-event__date-top {
  font-family: var(--font-body);
  font-size: clamp(18px, 2.5vw, 24px);
  font-weight: 700;
  color: var(--color-black);
  line-height: 1.3;
}

.spaces-event__date-bottom {
  font-family: var(--font-body);
  font-size: clamp(16px, 2vw, 20px);
  color: var(--color-black);
  opacity: 0.55;
  line-height: 1.3;
}

.spaces-event__name {
  font-family: var(--font-body);
  font-size: clamp(18px, 2.5vw, 24px);
  color: var(--color-black);
  font-weight: 700;
  letter-spacing: 0.02em;
  margin: 0 0 2px;
  font-variant: small-caps;
}

.spaces-event__description {
  font-family: var(--font-body);
  font-size: var(--text-md);
  color: var(--color-black);
  opacity: 0.75;
  margin: 0 0 4px;
  line-height: 1.4;
}

.spaces-event__location {
  font-family: var(--font-body);
  font-size: 11px;
  color: var(--color-black);
  opacity: 0.45;
  margin: 0;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.spaces-event__btn {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--color-black);
  border: 2px solid var(--color-black);
  padding: 8px 20px;
  border-radius: 4px;
  text-decoration: none;
  white-space: nowrap;
  transition: background var(--transition-fast), color var(--transition-fast);
}

.spaces-event__btn:hover {
  background: var(--color-black);
  color: var(--color-yellow);
}

@media (max-width: 600px) {
  .page-spaces__card {
    padding: 28px 24px 36px;
  }
  .spaces-event {
    grid-template-columns: 48px 1fr;
    grid-template-rows: auto auto;
  }
  .spaces-event__action {
    grid-column: 2;
    margin-top: 8px;
  }
}
</style>

