{% comment %}
  Product Detail Page — /products/seeker-black
  Desktop (3-col): Info (left) | Gallery + thumbs (centre) | Variant + CTA (right)
  Mobile (stacked): Gallery → Title → Price → Variant → CTA → Description → Pre-order
{% endcomment %}

<article
  class="product-page"
  id="product-page"
  itemscope
  itemtype="http://schema.org/Product"
>

  {%- comment -%}───────────── CENTRE — Gallery (source-first = mobile-first) ─────────────{%- endcomment -%}
  <div class="product-page__gallery" data-gallery>

    {%- comment -%} Mobile nav arrows (hidden on desktop) {%- endcomment -%}
    <button class="product-page__nav product-page__nav--prev" aria-label="Previous image" data-nav-prev>‹</button>
    <button class="product-page__nav product-page__nav--next" aria-label="Next image" data-nav-next>›</button>

    {%- comment -%} Main image {%- endcomment -%}
    <div class="product-page__main-image" data-images-container>
      {%- for image in product.images -%}
        <div class="product-page__slide{%- if forloop.first %} is-active{%- endif -%}" data-main-image="{{ forloop.index0 }}">
          <img
            src="{{ image | image_url: width: 1200 }}"
            alt="{{ image.alt | escape | default: product.title }}"
            width="{{ image.width }}"
            height="{{ image.height }}"
            class="product-page__main-img"
            loading="{%- if forloop.first -%}eager{%- else -%}lazy{%- endif -%}"
            itemprop="image"
          >
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} Thumbnail strip (desktop) {%- endcomment -%}
    {%- if product.images.size > 1 -%}
      <div class="product-page__thumbnails" role="list" aria-label="Product image views">
        {%- for image in product.images -%}
          <button
            class="product-page__thumb{%- if forloop.first %} is-active{%- endif -%}"
            data-thumb="{{ forloop.index0 }}"
            aria-label="{{ image.alt | escape | default: product.title }}"
            role="listitem"
          >
            <img
              src="{{ image | image_url: width: 200 }}"
              alt=""
              width="200"
              height="200"
              loading="lazy"
            >
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>

  {%- comment -%}───────────── NAME ─────────────{%- endcomment -%}
  <h1 class="product-page__name" itemprop="name">{{ product.title }}</h1>

  {%- comment -%}───────────── PRICE ─────────────{%- endcomment -%}
  <p class="product-page__price" itemprop="offers" itemscope itemtype="http://schema.org/Offer">
    <span itemprop="price" content="{{ product.selected_or_first_available_variant.price | divided_by: 100.0 }}">
      {{ product.selected_or_first_available_variant.price | money }}
    </span>
    <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
  </p>

  {%- comment -%}───────────── RIGHT — Variant + CTA ─────────────{%- endcomment -%}
  <div class="product-page__selection">

    {%- form 'product', product, id: 'product-form', data-product-form: '' -%}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-variant-id>

      {%- comment -%} Variant select dropdown {%- endcomment -%}
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <div class="product-page__variant-wrap">
            <select
              class="product-page__variant-select"
              name="{{ option.name }}"
              id="option-{{ option.name | downcase }}"
              aria-label="{{ option.name }}"
            >
              {%- for value in option.values -%}
                <option
                  value="{{ value }}"
                  {%- if option.selected_value == value %} selected{%- endif -%}
                >{{ value }}</option>
              {%- endfor -%}
            </select>
            <span class="product-page__select-chevron" aria-hidden="true">›</span>
          </div>
        {%- endfor -%}
      {%- endunless -%}

      {%- comment -%} Add to Cart {%- endcomment -%}
      <button
        type="submit"
        name="add"
        class="product-page__cta"
        {%- if product.selected_or_first_available_variant.available == false -%}disabled{%- endif -%}
      >
        {%- if product.selected_or_first_available_variant.available -%}
          Add to Cart
        {%- else -%}
          Sold Out
        {%- endif -%}
      </button>

    {%- endform -%}

  </div>

  {%- comment -%}───────────── LEFT — Info (description, pickup, preorder) ─────────────{%- endcomment -%}
  <div class="product-page__info">

    {%- if product.description != blank -%}
      <div class="product-page__description" itemprop="description">
        {{ product.description }}
      </div>
    {%- endif -%}


  </div>

</article>

{% schema %}
{
  "name": "Product Template",
  "settings": []
}
{% endschema %}
