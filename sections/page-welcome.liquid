<section class="page-welcome">
  <div class="page-welcome__inner">

    <h1 class="page-welcome__title">You're in —<br>Read the rest of the email to join your first Journal Club.</h1>

  </div>
</section>

<style>
.page-welcome {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80px var(--space-6);
}

.page-welcome__inner {
  max-width: 600px;
  text-align: center;
}

.page-welcome__title {
  font-family: var(--font-body);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(32px, 5vw, 56px);
  color: var(--color-yellow);
  margin: 0 0 16px;
}

.page-welcome__subtitle {
  font-family: var(--font-body);
  font-size: var(--text-md);
  color: var(--color-yellow);
  font-style: italic;
  opacity: 0.7;
  margin: 0 0 48px;
}

.page-welcome__body {
  font-family: var(--font-body);
  font-size: var(--text-md);
  color: var(--color-yellow);
  line-height: 1.8;
  margin-bottom: 48px;
}

.page-welcome__body p {
  margin: 0 0 16px;
}

.page-welcome__cta {
  display: inline-block;
  font-family: var(--font-body);
  font-size: var(--text-md);
  color: var(--color-black);
  background: var(--color-yellow);
  padding: 14px 32px;
  border-radius: 6px;
  text-decoration: none;
  font-weight: 700;
  transition: opacity var(--transition-fast);
}

.page-welcome__cta:hover {
  opacity: 0.85;
}
</style>

{% schema %}
{
  "name": "Welcome",
  "settings": []
}
{% endschema %}
