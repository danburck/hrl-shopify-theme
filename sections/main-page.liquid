<article
  class="container"
  style="padding-block: var(--space-16); max-width: 720px;"
  itemprop="mainContentOfPage"
>
  <h1 class="title title-xl" style="margin-bottom: var(--space-8);">
    {{ page.title }}
  </h1>
  <div class="text-md rte" style="line-height: 1.7;">
    {{ page.content }}
  </div>
</article>

{% schema %}
{
  "name": "Page Content",
  "settings": []
}
{% endschema %}
